{
  "name": "ai-content-portal",
  "private": true,
  "workspaces": [
    "web",
    "worker",
    "lib",
    "database"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=@repo/web & npm run dev --workspace=@repo/worker",
    "build": "npm run build --workspace=@repo/web",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "db:gen-types": "cd database && npm run gen:types"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
